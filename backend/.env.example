# ── YooKassa credentials ──────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Frontend URL (for CORS + return_url after payment) ────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://yourdomain.ru

# ── JWT secret (long random string, keep private) ─────────
JWT_SECRET=change_this_to_a_very_long_random_string_32chars

# ── Admin initial credentials (used only on first boot) ───
# After first boot, admin.json is created; change password via the admin panel.
ADMIN_EMAIL=fteammasha@gmail.com
ADMIN_PASSWORD=fteammasha112006FT

# ── Legacy admin token (for /participants endpoint) ────────
ADMIN_TOKEN=change_this_to_a_long_random_string

# ── SMTP (for email verification codes + password reset) ──
# Timeweb mail example:
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=your_smtp_password
